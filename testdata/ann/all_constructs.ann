# ann v0.3
// all supported constructs §8

[seeker] auth --verbose --depth=full
[activity] act-001 : single {{ slot }} and $ref context
[activity] act-002 :
  first context line
  second context line

$report = [seeker] query : find auth traces
$title = "literal with {{ slot | fallback }} and $binding"
$items = list("alpha", $title, "gamma")

[reviewer] $report
  success -> {
    $ok = "yes"
    [notify] stored
  }
  error -> {
    [ask-user] retry now
  }
  info -> {}

parallel {
  [seeker] --id=seek-a alpha
  [reviewer] --id=rev-b beta : parallel context
}
  each -> {
    [notify] $result
  }

foreach $items {
  [seeker] $item
}

loop limit=3 {
  [seeker] again
    success -> {
      [notify] done
    }
}

$r = [seeker] fetch

[activity] act-003 : track $r.status here
[echo] $r.payload.out
$paths = list($r.items, "static", $r.meta.path)
[return] --id=out $r.payload.result

foreach $r.items {
  [seeker] $item
}

if $r.status == "success" {
  [notify] $r.payload.result
}
else {
  [ask-user] retry
}

if $r.error != null {
  [notify] failure
}

loop limit=5 until $r.status == "success" {
  [seeker] poll
}
