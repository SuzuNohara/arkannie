Program
  Dispatch line=4 cmd=seeker args=["auth"] id="" ctx="" flags={depth="full" verbose=""}
  Dispatch line=5 cmd=activity args=["act-001"] id="" ctx="single {{ slot }} and $ref context" flags={}
  Dispatch line=6 cmd=activity args=["act-002"] id="" ctx="first context line\nsecond context line" flags={}
  Assign line=10 name=report
    Dispatch line=10 cmd=seeker args=["query"] id="" ctx="find auth traces" flags={}
  Assign line=11 name=title
    StrLit "literal with {{ slot | fallback }} and $binding"
  Assign line=12 name=items
    ListLit ["alpha" "$title" "gamma"]
  Dispatch line=14 cmd=reviewer args=["$report"] id="" ctx="" flags={}
    Handler success
      Assign line=16 name=ok
        StrLit "yes"
      Dispatch line=17 cmd=notify args=["stored"] id="" ctx="" flags={}
    Handler error
      Dispatch line=20 cmd=ask-user args=["retry" "now"] id="" ctx="" flags={}
    Handler info
  Parallel line=24
    Dispatch line=25 cmd=seeker args=["alpha"] id="seek-a" ctx="" flags={id="seek-a"}
    Dispatch line=26 cmd=reviewer args=["beta"] id="rev-b" ctx="parallel context" flags={id="rev-b"}
    Each
      Dispatch line=29 cmd=notify args=["$result"] id="" ctx="" flags={}
  Foreach line=32 list=$items
    Dispatch line=33 cmd=seeker args=["$item"] id="" ctx="" flags={}
  Loop line=36 limit=3
    Dispatch line=37 cmd=seeker args=["again"] id="" ctx="" flags={}
      Handler success
        Dispatch line=39 cmd=notify args=["done"] id="" ctx="" flags={}
  Assign line=43 name=r
    Dispatch line=43 cmd=seeker args=["fetch"] id="" ctx="" flags={}
  Dispatch line=45 cmd=activity args=["act-003"] id="" ctx="track $r.status here" flags={}
  Dispatch line=46 cmd=echo args=["$r.payload.out"] id="" ctx="" flags={}
  Assign line=47 name=paths
    ListLit ["$r.items" "static" "$r.meta.path"]
  Dispatch line=48 cmd=return args=["$r.payload.result"] id="out" ctx="" flags={id="out"}
  Foreach line=50 list=$r.items
    Dispatch line=51 cmd=seeker args=["$item"] id="" ctx="" flags={}
  If line=54 op=== left=$r.status right="success"
    Then
      Dispatch line=55 cmd=notify args=["$r.payload.result"] id="" ctx="" flags={}
    Else
      Dispatch line=58 cmd=ask-user args=["retry"] id="" ctx="" flags={}
  If line=61 op=!= left=$r.error right=null
    Then
      Dispatch line=62 cmd=notify args=["failure"] id="" ctx="" flags={}
  Loop line=65 limit=5 until op=== left=$r.status right="success"
    Dispatch line=66 cmd=seeker args=["poll"] id="" ctx="" flags={}
  Assign line=70 name=quoted
    StrLit "con \"comilla\" y \\backslash"
  Assign line=71 name=price
    StrLit "literal \\$5 sin interpolar"
  Dispatch line=72 cmd=echo args=["\\$literal"] id="" ctx="precio \\$5 sin interpolar" flags={}
  Dispatch line=74 cmd=activity args=["act-004"] id="" ctx="intro paragraph\n\n- item with detail\n    nested note" flags={}
  Assign line=80 name=nested
    ListLit ["a" "list(b)" "$r.items"]
  Assign line=81 name=joined
    Concat ["$items" "x"]
  Assign line=82 name=cfg
    MapLit ["k: v" "n: $r.campo" "anidado: map(c: d)" "lista: list(x)"]
  ParallelForeach line=84 list=$r.items base=W
    Dispatch line=85 cmd=echo args=[] id="" ctx="\"$item @ $index\"" flags={}
    Each
      Dispatch line=88 cmd=notify args=[] id="" ctx="\"$result\"" flags={}
  Dispatch line=91 cmd=seeker args=["retryable"] id="" ctx="" flags={backoff="1" retry="2"}
  Assign line=93 name=sub
    Call path="sub.ann"
  Call line=94 path="sub.ann"
